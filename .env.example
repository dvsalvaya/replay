ADMIN_USERNAME=
ADMIN_PASSWORD=
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
DATABASE_URL=sqlite:///./sports_highlights.db
VIDEOS_DIR=./storage/videos

# Camera
CAMERA_DEVICE_INDEX=0
CAMERA_FPS=15
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_JPEG_QUALITY=70

# Buffer
BUFFER_DURATION_SECONDS=120
BUFFER_MAX_FRAMES=1800

# Storage
TEMP_DIR=./storage/temp

# FFmpeg
FFMPEG_PATH=ffmpeg
FFMPEG_CRF=23
FFMPEG_PRESET=ultrafast

# TTL
TTL_DAYS=7
TTL_RUN_INTERVAL_HOURS=1
TTL_TEMP_MAX_AGE_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
